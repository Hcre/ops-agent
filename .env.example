# 选择模型 profile（见 config.py MODEL_PROFILES）
MODEL_PROFILE=deepseek-r1

# DeepSeek API
DEEPSEEK_API_KEY=sk-xxx
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1

# Qwen3（阿里云百炼 DashScope）
DASHSCOPE_API_KEY=sk-xxx
DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# 安全审查员使用轻量模型（降低延迟和成本）
SECURITY_REVIEWER_MODEL=qwen3-8b

# 运行模式：default / plan / auto
# default: 读操作允许，写操作询问
# plan:    仅允许只读（零写入风险）
# auto:    读操作自动放行，非高危写操作自动放行
AGENT_MODE=default
